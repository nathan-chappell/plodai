{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "frontend: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "frontend: build",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "backend: sync static",
      "type": "shell",
      "command": "Copy-Item -Path frontend/dist/* -Destination backend/app/static -Recurse -Force",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
          "args": [
            "-Command"
          ]
        }
      },
      "dependsOn": "frontend: build",
      "problemMatcher": []
    }
  ]
}
